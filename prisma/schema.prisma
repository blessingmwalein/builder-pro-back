generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  INDIVIDUAL
  COMPANY
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum ProjectType {
  RESIDENTIAL
  COMMERCIAL
  RENOVATION
  INFRASTRUCTURE
  INDUSTRIAL
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TimeEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum PaymentMethod {
  PAYNOW
  ECOCASH
  BANK_TRANSFER
  CASH
  CARD
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMMENT
  INVOICE_PAID
  INVOICE_OVERDUE
  BUDGET_THRESHOLD
  TIMESHEET_APPROVAL_REQUIRED
  QUOTE_SENT
  QUOTE_APPROVED
  QUOTE_REJECTED
  PROJECT_DEADLINE
  STOCK_LOW
  PROJECT_INVITE
  GENERAL
}

enum DocumentType {
  PHOTO
  PLAN
  CONTRACT
  RECEIPT
  PERMIT
  CERTIFICATE
  OTHER
}

enum MessageType {
  DIRECT
  PROJECT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  APPROVE
  REJECT
  EXPORT
}

enum ClientType {
  RESIDENTIAL
  COMMERCIAL
  GOVERNMENT
  OTHER
}

enum VariationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum VariationType {
  ADDITION
  OMISSION
  SUBSTITUTION
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  SUBCONTRACTOR
  CASUAL
}

model Company {
  id                    String                 @id @default(cuid())
  companyId             String                 @unique
  name                  String
  slug                  String                 @unique
  subdomain             String?                @unique
  industry              String?
  address               String?
  logoUrl               String?
  logoKey               String?
  accountType           AccountType            @default(COMPANY)
  countryCode           String                 @default("ZW")
  defaultCurrency       String                 @default("USD")
  timezone              String                 @default("Africa/Harare")
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  users                 User[]
  roles                 Role[]
  permissions           Permission[]
  projects              Project[]
  projectMembers        ProjectMember[]
  tasks                 Task[]
  taskComments          TaskComment[]
  taskAttachments       TaskAttachment[]
  taskChecklists        TaskChecklist[]
  taskChecklistItems    TaskChecklistItem[]
  timeEntries           TimeEntry[]
  materials             Material[]
  materialLogs          MaterialLog[]
  suppliers             Supplier[]
  quotes                Quote[]
  quoteLineItems        QuoteLineItem[]
  variations            Variation[]
  variationLineItems    VariationLineItem[]
  invoices              Invoice[]
  invoiceLineItems      InvoiceLineItem[]
  payments              Payment[]
  budgetCategories      BudgetCategory[]
  budgets               Budget[]
  financialTransactions FinancialTransaction[]
  costForecasts         CostForecast[]
  employees             Employee[]
  clients               Client[]
  conversations         Conversation[]
  messages              Message[]
  notifications         Notification[]
  documents             Document[]
  reports               Report[]
  subscriptionPlans     SubscriptionPlan[]
  subscriptions         Subscription[]
  webhooks              IntegrationWebhook[]
  auditLogs             AuditLog[]

  @@index([isActive, deletedAt])
}

model User {
  id                  String          @id @default(cuid())
  companyId           String
  email               String
  phone               String?
  passwordHash        String
  firstName           String
  lastName            String
  avatarUrl           String?
  avatarKey           String?
  accountType         AccountType     @default(COMPANY)
  isActive            Boolean         @default(true)
  inviteToken         String?         @unique
  inviteTokenExpiresAt DateTime?
  invitedById         String?
  lastLoginAt         DateTime?
  refreshTokenHash    String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  company             Company         @relation(fields: [companyId], references: [id])
  userRoles           UserRole[]
  assignedTasks       TaskAssignee[]
  taskComments        TaskComment[]
  approvedTimeEntries TimeEntry[]     @relation("TimeEntryApprover")
  timeEntries         TimeEntry[]     @relation("TimeEntryWorker")
  notifications       Notification[]
  employee            Employee?
  sentMessages        Message[]       @relation("MessageSender")
  readReceipts        MessageReceipt[]
  audits              AuditLog[]      @relation("AuditActor")
  generatedReports    Report[]        @relation("ReportGenerator")
  projectMemberships  ProjectMember[]

  @@unique([companyId, email])
  @@index([companyId, isActive, deletedAt])
}

model PlatformAdminUser {
  id          String   @id @default(cuid())
  email       String   @unique
  passwordHash String
  displayName String
  apiKeyHash  String   @unique
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Role {
  id          String           @id @default(cuid())
  companyId   String
  name        String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  company     Company          @relation(fields: [companyId], references: [id])
  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([companyId, name])
  @@index([companyId, deletedAt])
}

model Permission {
  id          String           @id @default(cuid())
  companyId   String
  key         String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  company     Company          @relation(fields: [companyId], references: [id])
  roles       RolePermission[]

  @@unique([companyId, key])
  @@index([companyId, deletedAt])
}

model UserRole {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([companyId, userId, roleId])
  @@index([companyId, deletedAt])
}

model RolePermission {
  id           String     @id @default(cuid())
  companyId    String
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([companyId, roleId, permissionId])
  @@index([companyId, deletedAt])
}

model Project {
  id                 String           @id @default(cuid())
  companyId          String
  clientId           String?
  projectManagerId   String?
  code               String
  name               String
  description        String?
  projectType        ProjectType      @default(OTHER)
  siteAddress        String?
  gpsLat             Decimal?         @db.Decimal(10, 7)
  gpsLng             Decimal?         @db.Decimal(10, 7)
  status             ProjectStatus    @default(DRAFT)
  startDate          DateTime?
  endDate            DateTime?
  actualEndDate      DateTime?
  baselineBudget     Decimal          @db.Decimal(18, 2)
  actualCost         Decimal          @default(0) @db.Decimal(18, 2)
  completionPercent  Int              @default(0)
  isArchived         Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?
  company            Company          @relation(fields: [companyId], references: [id])
  client             Client?          @relation(fields: [clientId], references: [id])
  tasks              Task[]
  timeEntries        TimeEntry[]
  materialLogs       MaterialLog[]
  quotes             Quote[]
  variations         Variation[]
  invoices           Invoice[]
  budgets            Budget[]
  transactions       FinancialTransaction[]
  forecasts          CostForecast[]
  conversations      Conversation[]
  documents          Document[]
  members            ProjectMember[]

  @@unique([companyId, code])
  @@index([companyId, status, deletedAt])
}

model ProjectMember {
  id        String   @id @default(cuid())
  companyId String
  projectId String
  userId    String
  role      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  company   Company  @relation(fields: [companyId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([companyId, projectId, userId])
  @@index([companyId, projectId, deletedAt])
}

model Task {
  id             String            @id @default(cuid())
  companyId      String
  projectId      String
  parentTaskId   String?
  title          String
  description    String?
  status         TaskStatus        @default(TODO)
  priority       Priority          @default(MEDIUM)
  startDate      DateTime?
  dueDate        DateTime?
  estimatedHours Decimal?          @db.Decimal(8, 2)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  company        Company           @relation(fields: [companyId], references: [id])
  project        Project           @relation(fields: [projectId], references: [id])
  parentTask     Task?             @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  subtasks       Task[]            @relation("TaskHierarchy")
  assignees      TaskAssignee[]
  checklists     TaskChecklist[]
  comments       TaskComment[]
  attachments    TaskAttachment[]
  timeEntries    TimeEntry[]

  @@index([companyId, projectId, status, dueDate])
  @@index([companyId, deletedAt])
}

model TaskAssignee {
  id        String   @id @default(cuid())
  companyId String
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  task      Task     @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([companyId, taskId, userId])
  @@index([companyId, deletedAt])
}

model TaskChecklist {
  id        String              @id @default(cuid())
  companyId String
  taskId    String
  title     String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  deletedAt DateTime?
  task      Task                @relation(fields: [taskId], references: [id])
  company   Company             @relation(fields: [companyId], references: [id])
  items     TaskChecklistItem[]

  @@index([companyId, taskId, deletedAt])
}

model TaskChecklistItem {
  id          String         @id @default(cuid())
  companyId   String
  checklistId String
  content     String
  isDone      Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  checklist   TaskChecklist  @relation(fields: [checklistId], references: [id])
  company     Company        @relation(fields: [companyId], references: [id])

  @@index([companyId, checklistId, deletedAt])
}

model TaskComment {
  id        String   @id @default(cuid())
  companyId String
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  task      Task     @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])

  @@index([companyId, taskId, createdAt])
}

model TaskAttachment {
  id          String   @id @default(cuid())
  companyId   String
  taskId      String
  fileKey     String
  fileName    String
  contentType String
  sizeBytes   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  task        Task     @relation(fields: [taskId], references: [id])
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId, taskId, deletedAt])
}

model TimeEntry {
  id              String          @id @default(cuid())
  companyId       String
  projectId       String
  taskId          String?
  workerId        String
  approvedById    String?
  clockInAt       DateTime
  clockOutAt      DateTime?
  breakMinutes    Int             @default(0)
  gpsInLat        Decimal?        @db.Decimal(10, 7)
  gpsInLng        Decimal?        @db.Decimal(10, 7)
  gpsOutLat       Decimal?        @db.Decimal(10, 7)
  gpsOutLng       Decimal?        @db.Decimal(10, 7)
  regularHours    Decimal         @default(0) @db.Decimal(8, 2)
  overtimeHours   Decimal         @default(0) @db.Decimal(8, 2)
  hourlyRate      Decimal         @default(0) @db.Decimal(12, 2)
  labourCost      Decimal         @default(0) @db.Decimal(18, 2)
  isManualEntry   Boolean         @default(false)
  notes           String?
  status          TimeEntryStatus @default(PENDING)
  approvalComment String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  project         Project         @relation(fields: [projectId], references: [id])
  task            Task?           @relation(fields: [taskId], references: [id])
  worker          User            @relation("TimeEntryWorker", fields: [workerId], references: [id])
  approver        User?           @relation("TimeEntryApprover", fields: [approvedById], references: [id])
  company         Company         @relation(fields: [companyId], references: [id])

  @@index([companyId, projectId, workerId, status])
  @@index([companyId, clockInAt])
}

model Supplier {
  id         String       @id @default(cuid())
  companyId  String
  name       String
  email      String?
  phone      String?
  address    String?
  website    String?
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?
  company    Company      @relation(fields: [companyId], references: [id])
  materials  Material[]
  materialLogs MaterialLog[]

  @@unique([companyId, name])
  @@index([companyId, deletedAt])
}

model Material {
  id          String        @id @default(cuid())
  companyId   String
  supplierId  String?
  name        String
  category    String?
  sku         String?
  unit        String
  unitCost    Decimal       @default(0) @db.Decimal(12, 2)
  stockOnHand Decimal       @default(0) @db.Decimal(14, 3)
  reorderAt   Decimal?      @db.Decimal(14, 3)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  company     Company       @relation(fields: [companyId], references: [id])
  supplier    Supplier?     @relation(fields: [supplierId], references: [id])
  logs        MaterialLog[]

  @@unique([companyId, sku])
  @@index([companyId, deletedAt])
}

model MaterialLog {
  id          String   @id @default(cuid())
  companyId   String
  projectId   String
  taskId      String?
  materialId  String
  supplierId  String?
  quantity    Decimal  @db.Decimal(14, 3)
  unitCost    Decimal  @db.Decimal(12, 2)
  totalCost   Decimal  @db.Decimal(18, 2)
  usedAt      DateTime
  notes       String?
  receiptKey  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  company     Company  @relation(fields: [companyId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id])
  material    Material @relation(fields: [materialId], references: [id])
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  @@index([companyId, projectId, usedAt])
}

model Quote {
  id             String      @id @default(cuid())
  companyId      String
  projectId      String?
  clientId       String
  quoteNumber    String
  title          String
  notes          String?
  paymentTerms   String?
  status         QuoteStatus @default(DRAFT)
  issueDate      DateTime
  expiryDate     DateTime?
  taxRate        Decimal     @default(0) @db.Decimal(5, 2)
  discountAmount Decimal     @default(0) @db.Decimal(18, 2)
  subtotal       Decimal     @default(0) @db.Decimal(18, 2)
  taxAmount      Decimal     @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal     @default(0) @db.Decimal(18, 2)
  sentAt         DateTime?
  approvedAt     DateTime?
  rejectedAt     DateTime?
  rejectionNotes String?
  convertedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  company        Company     @relation(fields: [companyId], references: [id])
  project        Project?    @relation(fields: [projectId], references: [id])
  client         Client      @relation(fields: [clientId], references: [id])
  lineItems      QuoteLineItem[]
  variations     Variation[]
  invoices       Invoice[]

  @@unique([companyId, quoteNumber])
  @@index([companyId, status, issueDate])
}

model QuoteLineItem {
  id          String   @id @default(cuid())
  companyId   String
  quoteId     String
  category    String
  description String
  quantity    Decimal  @db.Decimal(14, 3)
  unit        String?
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(18, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  quote       Quote    @relation(fields: [quoteId], references: [id])
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId, quoteId, deletedAt])
}

model Variation {
  id             String          @id @default(cuid())
  companyId      String
  projectId      String
  quoteId        String?
  variationNumber String
  title          String
  description    String?
  type           VariationType   @default(ADDITION)
  status         VariationStatus @default(DRAFT)
  subtotal       Decimal         @default(0) @db.Decimal(18, 2)
  taxAmount      Decimal         @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal         @default(0) @db.Decimal(18, 2)
  approvedAt     DateTime?
  rejectedAt     DateTime?
  rejectionNotes String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  company        Company         @relation(fields: [companyId], references: [id])
  project        Project         @relation(fields: [projectId], references: [id])
  quote          Quote?          @relation(fields: [quoteId], references: [id])
  lineItems      VariationLineItem[]

  @@unique([companyId, variationNumber])
  @@index([companyId, projectId, status])
}

model VariationLineItem {
  id          String    @id @default(cuid())
  companyId   String
  variationId String
  category    String
  description String
  quantity    Decimal   @db.Decimal(14, 3)
  unit        String?
  unitPrice   Decimal   @db.Decimal(12, 2)
  totalPrice  Decimal   @db.Decimal(18, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  variation   Variation @relation(fields: [variationId], references: [id])
  company     Company   @relation(fields: [companyId], references: [id])

  @@index([companyId, variationId, deletedAt])
}

model Invoice {
  id             String        @id @default(cuid())
  companyId      String
  projectId      String?
  clientId       String
  quoteId        String?
  invoiceNumber  String
  notes          String?
  paymentTerms   String?
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime
  dueDate        DateTime
  retentionPct   Decimal       @default(0) @db.Decimal(5, 2)
  subtotal       Decimal       @default(0) @db.Decimal(18, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal       @default(0) @db.Decimal(18, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(18, 2)
  balanceAmount  Decimal       @default(0) @db.Decimal(18, 2)
  sentAt         DateTime?
  paidAt         DateTime?
  voidedAt       DateTime?
  reminderSentAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  company        Company       @relation(fields: [companyId], references: [id])
  project        Project?      @relation(fields: [projectId], references: [id])
  client         Client        @relation(fields: [clientId], references: [id])
  quote          Quote?        @relation(fields: [quoteId], references: [id])
  lineItems      InvoiceLineItem[]
  payments       Payment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId, status, dueDate])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  companyId   String
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(14, 3)
  unit        String?
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(18, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId, invoiceId, deletedAt])
}

model Payment {
  id                String        @id @default(cuid())
  companyId         String
  invoiceId         String?
  subscriptionId    String?
  transactionRef    String
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amount            Decimal       @db.Decimal(18, 2)
  providerPayload   Json?
  paidAt            DateTime?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?
  company           Company       @relation(fields: [companyId], references: [id])
  invoice           Invoice?      @relation(fields: [invoiceId], references: [id])
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])

  @@unique([companyId, transactionRef])
  @@index([companyId, status, createdAt])
}

model BudgetCategory {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  code        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  company     Company  @relation(fields: [companyId], references: [id])
  budgets     Budget[]
  transactions FinancialTransaction[]

  @@unique([companyId, code])
  @@index([companyId, deletedAt])
}

model Budget {
  id              String   @id @default(cuid())
  companyId       String
  projectId       String
  categoryId      String
  plannedAmount   Decimal  @db.Decimal(18, 2)
  actualAmount    Decimal  @default(0) @db.Decimal(18, 2)
  varianceAmount  Decimal  @default(0) @db.Decimal(18, 2)
  thresholdPct    Int      @default(80)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  company         Company  @relation(fields: [companyId], references: [id])
  project         Project  @relation(fields: [projectId], references: [id])
  category        BudgetCategory @relation(fields: [categoryId], references: [id])

  @@unique([companyId, projectId, categoryId])
  @@index([companyId, projectId, deletedAt])
}

model FinancialTransaction {
  id           String   @id @default(cuid())
  companyId    String
  projectId    String
  categoryId   String
  reference    String?
  description  String
  amount       Decimal  @db.Decimal(18, 2)
  occurredAt   DateTime
  sourceType   String
  sourceId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  company      Company  @relation(fields: [companyId], references: [id])
  project      Project  @relation(fields: [projectId], references: [id])
  category     BudgetCategory @relation(fields: [categoryId], references: [id])

  @@index([companyId, projectId, occurredAt])
}

model CostForecast {
  id               String   @id @default(cuid())
  companyId        String
  projectId        String
  estimateAt       DateTime @default(now())
  costToComplete   Decimal  @db.Decimal(18, 2)
  projectedProfit  Decimal  @db.Decimal(18, 2)
  assumptions      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?
  company          Company  @relation(fields: [companyId], references: [id])
  project          Project  @relation(fields: [projectId], references: [id])

  @@index([companyId, projectId, estimateAt])
}

model Employee {
  id             String        @id @default(cuid())
  companyId      String
  userId         String?       @unique
  employeeCode   String
  jobTitle       String
  department     String?
  trade          String?
  idNumber       String?
  employmentType EmploymentType @default(FULL_TIME)
  hourlyRate     Decimal       @db.Decimal(12, 2)
  dayRate        Decimal?      @db.Decimal(12, 2)
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  company        Company       @relation(fields: [companyId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@unique([companyId, employeeCode])
  @@index([companyId, isActive, deletedAt])
}

model Client {
  id                String     @id @default(cuid())
  companyId         String
  name              String
  contactPerson     String?
  clientType        ClientType @default(OTHER)
  email             String?
  phone             String?
  address           String?
  notes             String?
  assignedManagerId String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?
  company           Company    @relation(fields: [companyId], references: [id])
  projects          Project[]
  quotes            Quote[]
  invoices          Invoice[]

  @@index([companyId, deletedAt])
}

model Conversation {
  id           String      @id @default(cuid())
  companyId    String
  type         MessageType
  projectId    String?
  title        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  company      Company     @relation(fields: [companyId], references: [id])
  project      Project?    @relation(fields: [projectId], references: [id])
  messages     Message[]
  participants ConversationParticipant[]

  @@index([companyId, type, deletedAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  companyId      String
  conversationId String
  userId         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@unique([companyId, conversationId, userId])
  @@index([companyId, conversationId, deletedAt])
}

model Message {
  id             String     @id @default(cuid())
  companyId      String
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?
  company        Company    @relation(fields: [companyId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User       @relation("MessageSender", fields: [senderId], references: [id])
  receipts       MessageReceipt[]

  @@index([companyId, conversationId, createdAt])
}

model MessageReceipt {
  id          String   @id @default(cuid())
  companyId   String
  messageId   String
  userId      String
  readAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  message     Message  @relation(fields: [messageId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([companyId, messageId, userId])
  @@index([companyId, deletedAt])
}

model Notification {
  id          String              @id @default(cuid())
  companyId   String
  userId      String
  type        NotificationType
  channel     NotificationChannel @default(IN_APP)
  title       String
  body        String
  isRead      Boolean             @default(false)
  metadata    Json?
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  company     Company             @relation(fields: [companyId], references: [id])
  user        User                @relation(fields: [userId], references: [id])

  @@index([companyId, userId, isRead, createdAt])
}

model Document {
  id          String       @id @default(cuid())
  companyId   String
  projectId   String?
  taskId      String?
  uploaderId  String?
  type        DocumentType @default(OTHER)
  fileKey     String
  fileName    String
  contentType String
  sizeBytes   Int
  folder      String?
  gpsLat      Decimal?     @db.Decimal(10, 7)
  gpsLng      Decimal?     @db.Decimal(10, 7)
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  company     Company      @relation(fields: [companyId], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])

  @@index([companyId, projectId, deletedAt])
}

model Report {
  id            String   @id @default(cuid())
  companyId     String
  generatedById String
  reportType    String
  filterPayload Json?
  fileKey       String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  company       Company  @relation(fields: [companyId], references: [id])
  generatedBy   User     @relation("ReportGenerator", fields: [generatedById], references: [id])

  @@index([companyId, reportType, createdAt])
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  companyId     String
  code          String
  name          String
  monthlyPrice  Decimal  @db.Decimal(12, 2)
  annualPrice   Decimal  @db.Decimal(12, 2)
  limits        Json
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  company       Company  @relation(fields: [companyId], references: [id])
  subscriptions Subscription[]

  @@unique([companyId, code])
  @@index([companyId, isActive, deletedAt])
}

model Subscription {
  id                String             @id @default(cuid())
  companyId         String
  planId            String
  platformPlanId    String?
  status            SubscriptionStatus @default(TRIAL)
  billingCycle      String             @default("MONTHLY")
  currentPeriodFrom DateTime
  currentPeriodTo   DateTime
  trialEndsAt       DateTime?
  canceledAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  company           Company            @relation(fields: [companyId], references: [id])
  plan              SubscriptionPlan   @relation(fields: [planId], references: [id])
  platformPlan      PlatformPlan?      @relation(fields: [platformPlanId], references: [id])
  payments          Payment[]

  @@index([companyId, status, currentPeriodTo])
}

model PlatformPlan {
  id                String       @id @default(cuid())
  code              String       @unique
  name              String
  description       String?
  targetAccountType AccountType?
  monthlyPrice      Decimal      @db.Decimal(12, 2)
  annualPrice       Decimal      @db.Decimal(12, 2)
  limits            Json
  features          Json?
  isActive          Boolean      @default(true)
  sortOrder         Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?
  subscriptions     Subscription[]

  @@index([isActive, deletedAt])
}

model IntegrationWebhook {
  id            String   @id @default(cuid())
  companyId     String
  provider      String
  eventType     String
  payload       Json
  processedAt   DateTime?
  status        String
  retryCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  company       Company  @relation(fields: [companyId], references: [id])

  @@index([companyId, provider, eventType, status])
}

model AuditLog {
  id          String      @id @default(cuid())
  companyId   String
  actorId     String?
  action      AuditAction
  entity      String
  entityId    String
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  company     Company     @relation(fields: [companyId], references: [id])
  actor       User?       @relation("AuditActor", fields: [actorId], references: [id])

  @@index([companyId, entity, entityId, createdAt])
  @@index([companyId, actorId, createdAt])
}
